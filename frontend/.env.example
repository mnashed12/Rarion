# ============================================
# Frontend Environment Variables Example
# Copy this file to .env and fill in your values
# ============================================

# Backend API URL
# The base URL for the Django REST API
VITE_API_URL=http://localhost:8000/api

# AWS S3 Bucket URL for displaying card images
# Format: https://{bucket-name}.s3.{region}.amazonaws.com
VITE_AWS_S3_BUCKET_URL=https://your-bucket-name.s3.us-east-1.amazonaws.com

# Optional: Application title
VITE_APP_TITLE=Pokemon Card Inventory

# Optional: Items per page for pagination
VITE_DEFAULT_PAGE_SIZE=20

# Password Protection (Keep these secret! Add to .env, not in code)
# Password to access the entire application
VITE_APP_PASSWORD=your-secure-app-password-here

# Per-user passwords — each password determines which user is logged in
VITE_USER1_PASSWORD=Minapokemon123!
VITE_USER2_PASSWORD=Dannypokemon123!
