# ============================================
# Environment Variables Example
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to git
# ============================================

# Django Settings
# Generate a new secret key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-super-secret-key-change-in-production

# Debug mode - set to False in production
DEBUG=True

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================
# PostgreSQL Database Configuration
# ============================================
DB_NAME=pokemon_inventory
DB_USER=pokemon_user
DB_PASSWORD=your_database_password
DB_HOST=localhost
DB_PORT=5432

# ============================================
# AWS S3 Configuration for Media Storage
# ============================================
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_STORAGE_BUCKET_NAME=your-s3-bucket-name
AWS_S3_REGION_NAME=us-east-1

# Optional: Custom S3 endpoint (for S3-compatible services)
# AWS_S3_ENDPOINT_URL=https://s3.amazonaws.com

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins for CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================
# Logging (optional)
# ============================================
LOG_LEVEL=DEBUG
